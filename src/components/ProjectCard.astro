---
import type { CollectionEntry } from "astro:content";

export interface Props {
  project: CollectionEntry<"projects">;
  gradient?: string;
  index?: number;
}
const {
  project,
  gradient = "from-teal-500/20 to-cyan-500/20",
  index = 0,
} = Astro.props;
const { data } = project;
const imageUrl = data.image || null;
const isEven = index % 2 === 0;
---

<!-- Mobile: vertical card (unchanged feel) -->
<article
  class="project-card-mobile md:hidden card card-hover overflow-hidden group"
>
  <a
    href={data.demoUrl || data.githubUrl || "#"}
    target={data.demoUrl || data.githubUrl ? "_blank" : undefined}
    rel={data.demoUrl || data.githubUrl ? "noopener noreferrer" : undefined}
    class="block"
  >
    <div
      class="aspect-video w-full overflow-hidden bg-gradient-to-br dark:from-[var(--bg-elevated)] dark:to-[var(--bg)]"
    >
      {
        imageUrl ? (
          <img
            src={imageUrl}
            alt={`${data.title} screenshot`}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div
            class={`flex h-full w-full items-center justify-center bg-gradient-to-br ${gradient} dark:from-[var(--bg-elevated)] dark:to-[var(--bg)]`}
          >
            <span
              class="font-display text-4xl font-bold select-none opacity-40"
              style="color: var(--text);"
            >
              {data.title.charAt(0)}
            </span>
          </div>
        )
      }
    </div>
  </a>
  <div class="p-4 md:p-5">
    <div class="flex items-start justify-between gap-2">
      <a
        href={data.demoUrl || data.githubUrl || "#"}
        target={data.demoUrl || data.githubUrl ? "_blank" : undefined}
        rel={data.demoUrl || data.githubUrl ? "noopener noreferrer" : undefined}
        class="font-display font-semibold text-lg transition-colors hover:opacity-90"
        style="color: var(--text);"
      >
        {data.title}
      </a>
      <div class="flex shrink-0 gap-1">
        {
          data.githubUrl && (
            <a
              href={data.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg p-1.5 transition-colors hover:bg-[var(--accent-muted)]"
              style="color: var(--text-muted);"
              aria-label="GitHub"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
            </a>
          )
        }
        {
          (data.demoUrl || data.githubUrl) && (
            <a
              href={data.demoUrl || data.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg p-1.5 transition-colors hover:bg-[var(--accent-muted)]"
              style="color: var(--text-muted);"
              aria-label="View demo"
            >
              <svg
                class="h-4 w-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                />
              </svg>
            </a>
          )
        }
      </div>
    </div>
    <p
      class="mt-2 text-sm leading-relaxed line-clamp-2"
      style="color: var(--text-muted);"
    >
      {data.description}
    </p>
    {
      data.techStack && data.techStack.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-1.5" aria-label="Tech">
          {data.techStack.slice(0, 5).map((tech) => (
            <li>
              <span
                class="rounded-md px-2 py-0.5 text-xs font-medium"
                style="background: var(--accent-muted); color: var(--accent);"
              >
                {tech}
              </span>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</article>

<!-- Desktop: inspired two-column layout -->
<div
  class="project-card-desktop hidden md:grid grid-cols-2 gap-6 lg:gap-10 items-center py-8 group"
>
  <!-- Image side -->
  <div class={`${isEven ? "order-1" : "order-2"}`}>
    <a
      href={data.demoUrl || data.githubUrl || "#"}
      target={data.demoUrl || data.githubUrl ? "_blank" : undefined}
      rel={data.demoUrl || data.githubUrl ? "noopener noreferrer" : undefined}
      class="block overflow-hidden rounded-xl border transition-all duration-500 group-hover:shadow-[0_0_30px_-5px_var(--accent)] group-hover:border-[var(--accent)]"
      style="border-color: var(--border);"
    >
      {
        imageUrl ? (
          <img
            src={imageUrl}
            alt={`${data.title} screenshot`}
            class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-[1.02]"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div
            class={`flex aspect-video w-full items-center justify-center bg-gradient-to-br ${gradient}`}
          >
            <span
              class="font-display text-6xl font-bold select-none opacity-20"
              style="color: var(--text);"
            >
              {data.title.charAt(0)}
            </span>
          </div>
        )
      }
    </a>
  </div>

  <!-- Content side -->
  <div class={`${isEven ? "order-2" : "order-1"} flex flex-col`}>
    <!-- Title -->
    <h3
      class="font-display font-bold text-3xl lg:text-4xl xl:text-5xl mb-6 transition-colors group-hover:opacity-90"
      style="color: var(--text);"
    >
      {data.title}
    </h3>

    <!-- Description box with accent background -->
    <div
      class="rounded-xl p-5 lg:p-6 mb-6"
      style="background: var(--accent-muted);"
    >
      <p
        class="text-sm lg:text-base leading-relaxed"
        style="color: var(--text-muted);"
      >
        {data.description}
      </p>
    </div>

    <!-- Tech stack as flat inline list -->
    {
      data.techStack && data.techStack.length > 0 && (
        <div class="flex flex-wrap gap-x-5 gap-y-2 mb-5">
          {data.techStack.map((tech) => (
            <span
              class="text-sm font-semibold tracking-wide"
              style="color: var(--accent);"
            >
              {tech}
            </span>
          ))}
        </div>
      )
    }

    <!-- Link icon -->
    <div class="flex items-center gap-3">
      {
        data.githubUrl && (
          <a
            href={data.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg p-1.5 transition-all hover:bg-[var(--accent-muted)] hover:scale-110"
            style="color: var(--text-muted);"
            aria-label="GitHub"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
        )
      }
      {
        (data.demoUrl || data.githubUrl) && (
          <a
            href={data.demoUrl || data.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg p-1.5 transition-all hover:bg-[var(--accent-muted)] hover:scale-110"
            style="color: var(--text-muted);"
            aria-label="View demo"
          >
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              />
            </svg>
          </a>
        )
      }
    </div>
  </div>
</div>
