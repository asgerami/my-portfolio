---
import Layout from "../layouts/Layout.astro";
import TechStack from "../components/TechStack.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const latestPosts = allPosts
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
  )
  .slice(0, 2);

const projects = await getCollection("projects");
projects.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.title.localeCompare(b.data.title);
});

const projectGradients = [
  "from-teal-500/20 to-cyan-500/20",
  "from-violet-500/20 to-fuchsia-500/20",
  "from-amber-500/20 to-orange-500/20",
];
---

<Layout title="Amir - Software Engineer" wideLayout={true}>
  <div class="py-8 md:py-12">
    <!-- Hero -->
    <section class="mb-12 md:mb-16 animate-fade-in">
      <p class="section-label mb-4">001. About</p>
      <h1
        class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-3"
        style="color: var(--text);"
      >
        Amir Aman
      </h1>
      <p
        class="text-xl md:text-2xl font-display font-medium mb-4 max-w-2xl"
        style="color: var(--accent);"
      >
        Software Engineer specializing in scalable web architectures.
      </p>
      <div
        class="max-w-2xl space-y-4 text-base md:text-lg leading-relaxed mb-8 flex flex-col"
        style="color: var(--text-muted);"
      >
        <p>
          I architect and build robust applications using Node.js, Next.js, and React. My focus is on crafting scalable backend systems, designing intuitive user experiences, and writing clean, maintainable code.
        </p>
        <p>
          Beyond web development, I have a strong interest in high-performance computing and Machine Learning. I'm currently expanding my expertise in C++ and exploring ML concepts, sharing my technical insights and discoveries on my blog.
        </p>
      </div>
      <div class="flex flex-wrap gap-4">
        <a
          href="https://www.linkedin.com/in/amiramaan/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl border-2 px-6 py-2.5 text-sm font-semibold transition-all hover:scale-[1.02]"
          style="border-color: var(--accent); color: var(--accent); background-color: transparent;"
        >
          View LinkedIn
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
            ></path>
          </svg>
        </a>
        <a
          href="https://github.com/asgerami"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl border-2 px-6 py-2.5 text-sm font-semibold transition-all hover:scale-[1.02]"
          style="border-color: var(--border); color: var(--text); background-color: var(--bg-elevated);"
        >
          View GitHub
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" /></svg>
        </a>
      </div>
    </section>

    <!-- Tech Stack -->
    <section
      class="section-reveal mb-16 md:mb-24"
      aria-labelledby="tech-heading"
    >
      <p class="section-label mb-3">002. Stack</p>
      <h2
        id="tech-heading"
        class="font-display text-2xl md:text-3xl font-bold mb-8"
        style="color: var(--text);"
      >
        Tech stack
      </h2>
      <div class="stagger-item">
        <TechStack />
      </div>
    </section>

    <!-- Projects -->
    <section
      class="section-reveal mb-16 md:mb-24"
      aria-labelledby="projects-heading"
    >
      <p class="section-label mb-3">003. Work</p>
      <h2
        id="projects-heading"
        class="font-display text-2xl md:text-3xl font-bold mb-8"
        style="color: var(--text);"
      >
        Projects
      </h2>
      {
        projects.length > 0 ? (
          <div
            class="flex flex-col gap-5 md:gap-0 md:divide-y"
            style="--tw-divide-opacity:1; border-color: var(--border);"
          >
            {projects.map((project, i) => (
              <div class="stagger-item">
                <ProjectCard
                  project={project}
                  gradient={projectGradients[i % projectGradients.length]}
                  index={i}
                />
              </div>
            ))}
          </div>
        ) : (
          <p class="text-base" style="color: var(--text-muted);">
            Projects coming soon.
          </p>
        )
      }
    </section>

    <!-- Blog -->
    <section class="section-reveal mb-8" aria-labelledby="blog-heading">
      <p class="section-label mb-3">004. Writing</p>
      <h2
        id="blog-heading"
        class="font-display text-2xl md:text-3xl font-bold mb-8"
        style="color: var(--text);"
      >
        Recent posts
      </h2>
      {
        latestPosts.length > 0 ? (
          <div class="space-y-4 mb-6">
            {latestPosts.map((post, i) => (
              <div class="stagger-item">
                <a
                  href={`/blog/${post.slug}`}
                  rel="prefetch"
                  class="card card-hover block p-5 md:p-6 group"
                >
                  <h3
                    class="font-display font-semibold text-lg mb-1 group-hover:opacity-90 transition-opacity"
                    style="color: var(--text);"
                  >
                    {post.data.title}
                  </h3>
                  <p
                    class="text-sm mb-3 line-clamp-2"
                    style="color: var(--text-muted);"
                  >
                    {post.data.description}
                  </p>
                  <time
                    class="text-xs font-medium"
                    style="color: var(--accent);"
                  >
                    {post.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                </a>
              </div>
            ))}
          </div>
        ) : (
          <p class="text-base mb-6" style="color: var(--text-muted);">
            No posts yet.
          </p>
        )
      }
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm font-semibold transition-colors hover:opacity-90"
        style="color: var(--accent);"
      >
        View all posts
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
        >
      </a>
    </section>
  </div>
</Layout>
