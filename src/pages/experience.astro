---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const experiences = await getCollection("experience");
experiences.sort(
  (a, b) =>
    new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime(),
);
---

<Layout
  title="Experience"
  description="Professional experience and career journey in software engineering."
  wideLayout={true}
>
  <div class="py-8 md:py-12">
    <header class="mb-12 md:mb-16 section-reveal">
      <p class="section-label mb-3">010. Experience</p>
      <h1 class="font-display text-3xl md:text-4xl font-bold mb-4" style="color: var(--text);">
        Work & roles
      </h1>
      <p class="text-base max-w-xl" style="color: var(--text-muted);">
        From learning the fundamentals to building production systems.
      </p>
    </header>

    {experiences.length > 0 ? (
      <div class="space-y-6 md:space-y-8">
        {experiences.map((experience, index) => (
          <div class="section-reveal">
          <article
            class="card card-hover p-6 md:p-8 flex flex-col md:flex-row md:gap-8"
          >
            <div class="md:w-44 shrink-0 flex flex-row md:flex-col md:justify-start gap-2 md:gap-1">
              <span
                class="inline-flex items-center justify-center w-10 h-10 rounded-xl text-sm font-display font-bold shrink-0"
                style="background: var(--accent-muted); color: var(--accent);"
                aria-hidden="true"
              >
                {String(index + 1).padStart(2, "0")}
              </span>
              <div class="flex flex-col min-w-0">
                <time class="text-sm font-medium" style="color: var(--text-muted);">
                  {new Date(experience.data.startDate).toLocaleDateString("en-US", { month: "short", year: "numeric" })}
                  {" – "}
                  {experience.data.endDate
                    ? new Date(experience.data.endDate).toLocaleDateString("en-US", { month: "short", year: "numeric" })
                    : "Present"}
                </time>
                {experience.data.current && (
                  <span
                    class="mt-1.5 inline-flex w-fit items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold"
                    style="background: var(--accent-muted); color: var(--accent);"
                  >
                    <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse" />
                    Current
                  </span>
                )}
              </div>
            </div>

            <div class="min-w-0 flex-1 pt-4 md:pt-0 border-t md:border-t-0 md:border-l border-[var(--border)] md:pl-8">
              <div class="flex flex-wrap items-baseline gap-2 mb-2">
                <h2 class="font-display font-semibold text-xl" style="color: var(--text);">
                  {experience.data.position}
                </h2>
                <span class="text-base font-medium" style="color: var(--accent);">
                  {experience.data.company}
                </span>
              </div>
              <p class="text-sm md:text-base leading-relaxed mb-5" style="color: var(--text-muted);">
                {experience.data.description}
              </p>
              {experience.data.technologies && experience.data.technologies.length > 0 && (
                <ul class="flex flex-wrap gap-2">
                  {experience.data.technologies.map((tech) => (
                    <li>
                      <span
                        class="rounded-md px-2.5 py-1 text-xs font-medium"
                        style="background: var(--accent-muted); color: var(--accent);"
                      >
                        {tech}
                      </span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </article>
          </div>
        ))}
      </div>
    ) : (
      <div class="card p-12 text-center">
        <h2 class="font-display text-xl font-semibold mb-2" style="color: var(--text);">
          Experience coming soon
        </h2>
        <p class="text-sm mb-6" style="color: var(--text-muted);">
          I’m updating this section. Check back soon.
        </p>
        <a href="/" class="text-sm font-semibold" style="color: var(--accent);">
          Back to home
        </a>
      </div>
    )}
  </div>
</Layout>
