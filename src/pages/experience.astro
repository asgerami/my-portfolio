---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const experiences = await getCollection("experience");
experiences.sort(
  (a, b) =>
    new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime(),
);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("en-US", {
    month: "short",
    year: "numeric",
  });
}

function getDuration(start: string, end?: string) {
  const startDate = new Date(start);
  const endDate = end ? new Date(end) : new Date();
  const months =
    (endDate.getFullYear() - startDate.getFullYear()) * 12 +
    (endDate.getMonth() - startDate.getMonth());
  const years = Math.floor(months / 12);
  const remainingMonths = months % 12;
  if (years > 0 && remainingMonths > 0) return `${years}y ${remainingMonths}m`;
  if (years > 0) return `${years}y`;
  return `${remainingMonths || 1}m`;
}
---

<Layout
  title="Experience"
  description="Professional experience and career journey in software engineering."
  wideLayout={true}
>
  <div class="exp-page py-8 md:py-12">
    <!-- Hero Header -->
    <header class="exp-hero section-reveal mb-14 md:mb-20">
      <div class="exp-hero__label-row">
        <p class="section-label mb-0">010. Experience</p>
        <span class="exp-hero__line"></span>
      </div>
      <h1 class="exp-hero__title">
        Career <span class="exp-hero__title-accent">Journey</span>
      </h1>
      <p class="exp-hero__subtitle">
        Each role shaped my skills and perspective - from robotics mentoring to
        building production-grade web systems.
      </p>
    </header>

    {experiences.length > 0 ? (
      <div class="exp-timeline" id="exp-timeline">
        <!-- Vertical line with scroll-tracking fill -->
        <div class="exp-timeline__track" aria-hidden="true">
          <div class="exp-timeline__fill" id="timeline-fill"></div>
        </div>

        {experiences.map((experience, index) => (
          <div
            class={`exp-timeline__item section-reveal ${index % 2 === 0 ? "exp-timeline__item--left" : "exp-timeline__item--right"}`}
          >
            <!-- Timeline Node -->
            <div class="exp-timeline__node" aria-hidden="true">
              <div class={`exp-timeline__dot ${experience.data.current ? "exp-timeline__dot--active" : ""}`}>
                {experience.data.current && (
                  <span class="exp-timeline__dot-ping"></span>
                )}
              </div>
            </div>

            <!-- Date Badge (desktop: opposite side of card) -->
            <div class="exp-timeline__date-badge">
              <time>
                {formatDate(experience.data.startDate)}
                {"  "}
                {experience.data.endDate
                  ? formatDate(experience.data.endDate)
                  : "Present"}
              </time>
            </div>

            <!-- Card -->
            <article class="exp-card">
              <div class="exp-card__inner">
                {/* Header: current badge only */}
                {experience.data.current && (
                  <div class="exp-card__header">
                    <span class="exp-card__current-badge">
                      <span class="exp-card__current-dot"></span>
                      Currently Active
                    </span>
                  </div>
                )}

                {/* Position & company */}
                <h2 class="exp-card__position">{experience.data.position}</h2>
                <div class="exp-card__company">
                  <svg
                    class="exp-card__company-icon"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                    />
                  </svg>
                  {experience.data.company}
                </div>

                {/* Mobile date */}
                <div class="exp-card__date-mobile">
                  <svg
                    class="exp-card__date-icon"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                    />
                  </svg>
                  <time>
                    {formatDate(experience.data.startDate)} –{" "}
                    {experience.data.endDate
                      ? formatDate(experience.data.endDate)
                      : "Present"}
                  </time>
                </div>

                {/* Description */}
                <p class="exp-card__description">{experience.data.description}</p>

                {/* Technologies */}
                {experience.data.technologies &&
                  experience.data.technologies.length > 0 && (
                    <div class="exp-card__tech-section">
                      <ul class="exp-card__tech-list">
                        {experience.data.technologies.map((tech) => (
                          <li class="exp-card__tech-tag">
                            {tech}
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
              </div>
            </article>
          </div>
        ))}
      </div>
    ) : (
      <div class="card p-12 text-center">
        <h2
          class="font-display text-xl font-semibold mb-2"
          style="color: var(--text);"
        >
          Experience coming soon
        </h2>
        <p class="text-sm mb-6" style="color: var(--text-muted);">
          I'm updating this section. Check back soon.
        </p>
        <a href="/" class="text-sm font-semibold" style="color: var(--accent);">
          Back to home
        </a>
      </div>
    )}
  </div>
</Layout>

<script>
  function initTimeline() {
    const timeline = document.getElementById("exp-timeline");
    const fill = document.getElementById("timeline-fill");
    if (!timeline || !fill) return;

    const dots = timeline.querySelectorAll(".exp-timeline__dot");
    const track = timeline.querySelector(".exp-timeline__track");

    function update() {
      if (!timeline || !fill) return;
      const trackRect = track ? track.getBoundingClientRect() : timeline.getBoundingClientRect();
      const viewportH = window.innerHeight;

      // Reference point: fill tracks a line ~55% down the viewport
      const fillEdgeY = viewportH * 0.55;

      // Scroll-based progress
      const scrolledPx = fillEdgeY - trackRect.top;
      const trackH = trackRect.height;
      let progress = Math.max(0, Math.min(1, scrolledPx / trackH));

      // When user is at or near the bottom of the page, force fill to 100%
      const maxScroll = document.documentElement.scrollHeight - viewportH;
      const currentScroll = window.scrollY || document.documentElement.scrollTop;
      if (maxScroll > 0 && currentScroll >= maxScroll - 5) {
        progress = 1;
      }

      if (fill) fill.style.height = `${progress * 100}%`;

      // Illuminate dots when the fill reaches them
      const fillAbsoluteY = fillEdgeY;
      dots.forEach((dot) => {
        const dotRect = dot.getBoundingClientRect();
        const dotCenterY = dotRect.top + dotRect.height / 2;

        if (dotCenterY <= fillAbsoluteY || progress === 1) {
          dot.classList.add("exp-timeline__dot--lit");
        } else {
          dot.classList.remove("exp-timeline__dot--lit");
        }
      });
    }

    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update, { passive: true });
    update();
  }

  document.addEventListener("DOMContentLoaded", initTimeline);
  document.addEventListener("astro:page-load", initTimeline);
</script>

<style>
  /* ===== Hero ===== */
  .exp-hero__label-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .exp-hero__line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--accent) 0%, transparent 100%);
    opacity: 0.4;
  }

  .exp-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .exp-hero__title-accent {
    background: linear-gradient(135deg, var(--accent) 0%, #818cf8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .exp-hero__subtitle {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 36rem;
  }

  /* ===== Timeline Container ===== */
  .exp-timeline {
    position: relative;
    padding: 1rem 0 4rem;
  }

  /* ===== Vertical Track (scroll-tracking) ===== */
  .exp-timeline__track {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    transform: translateX(-50%);
    background: var(--border);
    z-index: 0;
    border-radius: 2px;
    overflow: hidden;
  }

  .exp-timeline__fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: linear-gradient(180deg, var(--accent), #818cf8);
    border-radius: 2px;
    transition: height 0.15s ease-out;
    box-shadow: 0 0 8px rgba(45, 212, 191, 0.35);
  }

  /* ===== Timeline Item ===== */
  .exp-timeline__item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 3.5rem;
  }

  .exp-timeline__item:last-child {
    margin-bottom: 0;
  }

  /* ===== Node (center dot) ===== */
  .exp-timeline__node {
    display: flex;
    align-items: center;
    justify-content: center;
    grid-column: 2;
    grid-row: 1;
    z-index: 2;
  }

  .exp-timeline__dot {
    position: relative;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg-elevated);
    border: 3px solid var(--border);
    transition: all 0.4s ease;
  }

  .exp-timeline__dot--active {
    width: 16px;
    height: 16px;
    border-color: var(--accent);
    background: var(--accent);
    box-shadow: 0 0 16px rgba(45, 212, 191, 0.5);
  }

  /* Dots illuminate when the scroll fill reaches them */
  .exp-timeline__dot--lit:not(.exp-timeline__dot--active) {
    border-color: var(--accent);
    background: var(--accent);
    box-shadow: 0 0 12px rgba(45, 212, 191, 0.4);
    transform: scale(1.15);
  }

  .exp-timeline__dot-ping {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    opacity: 0;
    animation: ping-ring 2.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes ping-ring {
    0% {
      transform: scale(0.8);
      opacity: 0.6;
    }
    100% {
      transform: scale(2.2);
      opacity: 0;
    }
  }

  /* ===== Date Badge ===== */
  .exp-timeline__date-badge {
    display: none;
  }

  @media (min-width: 768px) {
    .exp-timeline__date-badge {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      padding-top: 1.75rem;
    }

    .exp-timeline__date-badge time {
      font-family: var(--font-display);
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-muted);
    }

    .exp-timeline__duration {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--accent);
      opacity: 0.8;
    }

    /* Left items: card left, date right */
    .exp-timeline__item--left .exp-timeline__date-badge {
      grid-column: 3;
      grid-row: 1;
      text-align: left;
    }
    .exp-timeline__item--left article {
      grid-column: 1;
      grid-row: 1;
    }

    /* Right items: card right, date left */
    .exp-timeline__item--right .exp-timeline__date-badge {
      grid-column: 1;
      grid-row: 1;
      text-align: right;
    }
    .exp-timeline__item--right article {
      grid-column: 3;
      grid-row: 1;
    }
  }

  /* ===== Card ===== */
  .exp-card {
    position: relative;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .exp-card:hover {
    border-color: color-mix(in srgb, var(--accent) 50%, transparent);
    transform: translateY(-3px);
    box-shadow:
      0 16px 48px -12px rgba(0, 0, 0, 0.08),
      0 0 0 1px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  :global(.dark) .exp-card:hover {
    box-shadow:
      0 16px 48px -12px rgba(0, 0, 0, 0.35),
      0 0 0 1px color-mix(in srgb, var(--accent) 25%, transparent);
  }

  .exp-card__inner {
    padding: 1.5rem 1.75rem;
  }

  /* Card Header (only current badge) */
  .exp-card__header {
    margin-bottom: 0.75rem;
  }

  .exp-card__current-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #10b981;
    background: rgba(16, 185, 129, 0.08);
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .exp-card__current-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #10b981;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  /* Position & Company */
  .exp-card__position {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }

  .exp-card__company {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .exp-card__company-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* Mobile Date */
  .exp-card__date-mobile {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .exp-card__date-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    opacity: 0.4;
  }

  .exp-card__duration-pill {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-muted);
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
  }

  @media (min-width: 768px) {
    .exp-card__date-mobile {
      display: none;
    }
  }

  /* Description */
  .exp-card__description {
    font-size: 0.875rem;
    line-height: 1.75;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  /* Tech Stack */
  .exp-card__tech-section {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  .exp-card__tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .exp-card__tech-tag {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.3rem 0.625rem;
    border-radius: 0.375rem;
    background: var(--accent-muted);
    color: var(--accent);
    border: 1px solid transparent;
    transition: all 0.25s ease;
    cursor: default;
  }

  .exp-card:hover .exp-card__tech-tag {
    border-color: rgba(45, 212, 191, 0.12);
  }

  .exp-card__tech-tag:hover {
    background: var(--accent);
    color: var(--bg);
    transform: translateY(-1px);
  }

  /* ===== Mobile Layout ===== */
  @media (max-width: 767px) {
    .exp-timeline__track {
      left: 19px;
    }

    .exp-timeline__item {
      display: flex;
      gap: 0.75rem;
      padding-left: 0;
    }

    .exp-timeline__node {
      flex-shrink: 0;
      width: 38px;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding-top: 1.5rem;
    }

    .exp-timeline__item--left article,
    .exp-timeline__item--right article {
      flex: 1;
      min-width: 0;
    }
  }
</style>
