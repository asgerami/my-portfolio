---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
posts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<Layout
  title="Blog"
  description="Thoughts on software engineering, technology, and building software."
  wideLayout={true}
>
  <div class="py-8 md:py-12">
    <p class="section-label mb-3">011. Blog</p>
    <h1 class="font-display text-3xl md:text-4xl font-bold mb-4" style="color: var(--text);">
      Writing
    </h1>
    <p class="text-base mb-12 max-w-xl" style="color: var(--text-muted);">
      Thoughts, recommendations, and what I’m learning.
    </p>

    {posts.length > 0 ? (
      <div class="space-y-4">
        {posts.map((post) => (
          <article class="card card-hover">
            <a href={`/blog/${post.slug}`} class="block p-5 md:p-6 group">
              <h2 class="font-display font-semibold text-lg mb-2 group-hover:opacity-90 transition-opacity" style="color: var(--text);">
                {post.data.title}
              </h2>
              <p class="text-sm mb-4 line-clamp-2" style="color: var(--text-muted);">
                {post.data.description}
              </p>
              <div class="flex flex-wrap items-center justify-between gap-3">
                <time class="text-xs font-medium" style="color: var(--accent);" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
                </time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <ul class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <li>
                        <span
                          class="rounded-md px-2 py-0.5 text-xs font-medium"
                          style="background: var(--accent-muted); color: var(--accent);"
                        >
                          #{tag}
                        </span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="card p-12 text-center">
        <h2 class="font-display text-xl font-semibold mb-2" style="color: var(--text);">
          Posts coming soon
        </h2>
        <p class="text-sm" style="color: var(--text-muted);">
          I’m working on posts about software engineering and my learning journey. Check back soon.
        </p>
      </div>
    )}
  </div>
</Layout>
